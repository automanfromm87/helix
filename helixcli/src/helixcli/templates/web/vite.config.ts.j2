    // the URL form keeps this working on any Node 18+ runtime.
    alias: { '@': fileURLToPath(new URL('./src', import.meta.url)) },
  },
  // host 0.0.0.0 so the helix sandbox port-forward reaches the dev server.
  // strictPort makes Vite fail loudly on conflicts instead of silently
  // picking a different port the proxy doesn't know about.
  server: { host: '0.0.0.0', port: 5173, strictPort: true },
  build: { target: 'es2022', sourcemap: true },
})
