"""Top-level API router. Sub-routers (one per resource) register here.

helixcli endpoint <METHOD> <path> appends `from .<resource> import
router as <resource>_router; api_router.include_router(<resource>_router)`
below.
"""
from fastapi import APIRouter

from .health import router as health_router

api_router = APIRouter()
api_router.include_router(health_router)
